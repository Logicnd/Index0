{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/generate-client-config.js",
  "installCommand": "",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://index0-backend.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://index0-backend.onrender.com/socket.io/:path*"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    }
  ]
}
